{
  "name": "ecom-neo-astro",
  "type": "module",
  "author": "Jimmy Huynh",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node dist/server/entry.mjs",
    "bundle-lambda": "esbuild dist/server/entry.mjs --bundle --platform=node --target=node20 --format=esm --outfile=.amplify-hosting/compute/default/entry.mjs --minify --tree-shaking=true --external:node:* --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url); import stream from 'stream'; globalThis.Stream = stream;\" --sourcemap",
    "test-lambda": "node .amplify-hosting/compute/default/test-lambda.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nanostores/react": "^0.8.4",
    "@radix-ui/react-separator": "^1.1.2",
    "astro": "^5.7.10",
    "astro-aws-amplify": "^0.1.0",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.5",
    "framer-motion": "^12.7.3",
    "lodash": "^4.17.21",
    "lucide-react": "^0.483.0",
    "nanostores": "^0.11.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@astrojs/react": "4.2.3",
    "@astrojs/tailwind": "6.0.2",
    "@types/dompurify": "^3.2.0",
    "@types/lodash": "^4.17.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.25.3",
    "tailwindcss": "3.4.1",
    "typescript": "^5.8.3"
  }
}
