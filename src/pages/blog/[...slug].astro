---
import BlogDetail from '@/components/BlogDetail';
import Layout from '@/layouts/Layout.astro';
import Meta from '@/components/Meta/metadata.astro';

// Tell Astro this is a dynamic route
export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  throw new Error('Slug parameter is missing from route.');
}
---

<Layout>
  <Meta
    slot='meta'
    title='Bài viết'
    description='Đọc bài viết mới nhất về thuỷ canh hữu cơ và nông nghiệp bền vững tại Không gian nhà nông.'
  />
  <BlogDetail slot='content' client:load slug={slug} />
</Layout>
