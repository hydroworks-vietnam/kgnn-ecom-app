---
import { postService } from '@/services/postService';
import BlogDetail from '@/components/BlogDetail';
import Layout from '@/layouts/Layout.astro';
import Meta from '@/components/Meta/index.astro';

// Tell Astro this is a dynamic route
export const prerender = false;

const { slug } = Astro.params;

let post;

try {
  post = await postService.getPostBySlug(slug);

  if (!post) {
    return Astro.redirect('/404', 302);
  }

  // Get related posts
  // relatedPosts = await postService.getRelatedPosts(post.id, 3);
} catch (error) {
  console.error('Error loading post:', error);
  return Astro.redirect('/404', 302);
}
---

<Layout>
  <Meta slot='meta' title={post.title} />
  <BlogDetail slot='content' client:load post={post} />
</Layout>
