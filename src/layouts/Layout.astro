---
import Header from '@/components/Header';
import Footer from '@/components/Footer/PageFooter.astro';
import '@/styles/global.css';
import CategoryHorizontalBar from '@/components/ui/CategoryHorizontalBar';
---

<!doctype html>
<html lang='en'>
  <head>
    <slot name='meta' />
  </head>
  <body class='max-w-full overflow-x-hidden'>
    <Header client:load />
    <CategoryHorizontalBar client:load />
    <main class='px-4 md:px-8 lg:px-36 pb-10 overflow-x-hidden'>
      <slot name='content' />
      <slot name='modal' />
      <slot name='dialog' />
      <slot name='snack' />
      <slot name='menu-drawer' />
    </main>
    <Footer />
  </body>
</html>